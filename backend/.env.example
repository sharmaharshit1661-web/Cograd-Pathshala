# Port on which the Express server will run
PORT=4000

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/cograd-pathshala

# JWT Secret Key for token generation
JWT_SECRET=your_jwt_secret_key_here

# Cloudinary — file storage for teacher documents
# Get these from https://cloudinary.com/console  (free account)
# Option A: Individual credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Option B: Single connection string
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# Google Client ID for Sign in with Google (optional in dev mode)
GOOGLE_CLIENT_ID=your_google_client_id_here

